# Copia este fichero como .env.local y rellena los valores de tu proyecto Supabase
# Supabase Dashboard → Project Settings → API Keys

# URL del proyecto (Project Settings → General → Reference ID → https://<ref>.supabase.co)
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Publishable key (pestaña "Publishable and secret API keys" → Publishable key → sb_publishable_...)
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
